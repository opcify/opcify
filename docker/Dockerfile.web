FROM node:22-slim AS base
RUN corepack enable pnpm

WORKDIR /app

# Install dependencies only — skip the root `postinstall` at this stage
# because it needs packages/core/ source + Prisma schema, which we haven't
# copied yet. We run the equivalent steps explicitly after the source copy.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json ./
COPY apps/web/package.json apps/web/
COPY packages/core/package.json packages/core/
ENV DATABASE_URL="file:/tmp/build.db"
RUN pnpm install --frozen-lockfile --ignore-scripts

# Source + build. The web package only needs @opcify/core at build time,
# not Prisma — but the root postinstall would run `prisma generate`, so we
# keep the schema around for parity (no functional runtime dep).
COPY prisma/ prisma/
COPY packages/core/ packages/core/
COPY apps/web/ apps/web/
RUN pnpm --filter @opcify/core build \
    && pnpm --filter @opcify/web build

EXPOSE 3210
CMD ["pnpm", "--filter", "@opcify/web", "start"]
