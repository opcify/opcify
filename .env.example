# ─── Database ───────────────────────────────────────────
DATABASE_URL="file:./opcify.db"

# ─── API Server ─────────────────────────────────────────
API_PORT=4210
API_HOST=127.0.0.1

# ─── Adapter Mode ───────────────────────────────────────
# "prisma" = SQLite + Prisma (default)
# "filesystem" = JSON file-based persistence
ADAPTER_MODE=prisma

# Path to OpenClaw workspace (only used when ADAPTER_MODE=filesystem)
# OPENCLAW_WORKSPACE=/path/to/workspace/openclaw

# ─── Redis (BullMQ task queue) ─────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Task Dispatch Callbacks ──────────────────────────
# Base URL that OpenClaw calls back to report task progress
OPCIFY_CALLBACK_URL=http://host.docker.internal:4210

# Optional: Bearer token for callback authentication
# OPCIFY_CALLBACK_TOKEN=

# ─── OpenClaw Integration ───────────────────────────────
# Base URL of the OpenClaw runtime (direct execution endpoint)
# Each workspace also has its own gateway — this is the global fallback.
# OPENCLAW_BASE_URL=http://localhost:5000

# Auth token for the OpenClaw runtime (sent as Bearer header)
# OPENCLAW_AUTH_TOKEN=

# ─── OpenClaw Gateway Webhook ─────────────────────────
# Gateway token for dispatching tasks via `openclaw agent` CLI
# Copy from ~/.openclaw/openclaw.json → gateway.auth.token
# OPENCLAW_GATEWAY_TOKEN=

# Which agent to route tasks to (default: main)
# OPENCLAW_GATEWAY_AGENT=main

# ─── Google OAuth — Login/Signup ──────────────────────
# Uses the OAuth 2.0 authorization-code flow (full-page redirect).
# Get these from Google Cloud Console → Credentials → OAuth 2.0 Client IDs.
# Required Cloud Console setup for this client:
#   - Application type: Web application
#   - Authorized redirect URIs MUST include:
#       http://localhost:3210/auth/google/callback
#       (and your production origin + /auth/google/callback)
#   - "Authorized JavaScript origins" is NOT used by this flow — leave it empty.
# IMPORTANT: this client is login-only — its OAuth consent screen must NOT
# have the Gmail scope registered, otherwise it will appear on the login popup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google OAuth — Gmail (Inbox connect) ─────────────
# Separate client so the Gmail scope is NOT shown on the login/signup consent
# screen. Register a second OAuth 2.0 Client in Google Cloud Console with ONLY
# the https://mail.google.com/ scope, then paste the values here.
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=

# ─── Docker Workspace Lifecycle ──────────────────────────
# Root directory where workspace data is stored on disk
# Default: ~/.opcify/workspaces
# Supports ~ for home directory expansion
# WORKSPACE_DATA_ROOT=~/.opcify/workspaces

# Docker socket path (OPCIFY_RUNTIME_MODE=docker only)
# Default: /var/run/docker.sock
# macOS Docker Desktop: /Users/<you>/.docker/run/docker.sock
# DOCKER_SOCKET_PATH=/var/run/docker.sock

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4210
NEXT_PUBLIC_APP_URL=http://localhost:3210
# Optional: override the Google Client ID used by the frontend
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Required on the frontend for the Inbox → Connect Gmail button (mirror of
# GOOGLE_GMAIL_CLIENT_ID above; the client id is public).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_GMAIL_CLIENT_ID=
